# ====== Copia este archivo a .env y ajusta para tu entorno ======
# Variables marcadas como [PROD] DEBEN cambiarse antes de ir a producción.

# --- App ---
# [PROD] Genera una clave robusta, p. ej.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=720
# [PROD] Orígenes permitidos (dominios reales del frontend), separados por comas.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Base de datos (coincide con docker-compose) ---
# [PROD] Usa credenciales fuertes y, si es gestionada, su URL real.
DATABASE_URL=postgresql+psycopg2://reportes:reportes@db:5432/reportes

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
# true en Docker (worker + beat). false sólo para ejecución local en proceso.
USE_CELERY=true

# --- Almacenamiento de archivos generados ---
OUTBOX_DIR=/data/outbox

# --- Programación ---
# Zona horaria (IANA) en la que se interpretan los cron de los reportes.
# Por defecto, horario local de Chile continental.
SCHEDULER_TIMEZONE=America/Santiago

# ====== Integración Datadog Cloud SIEM ======
# mock = datos de ejemplo (sin credenciales) | real = usa la API de Datadog
# [PROD] Cambiar a "real".
DATADOG_MODE=mock
# [PROD] API key de la organización (Organization Settings > API Keys).
DATADOG_API_KEY=
# [PROD] Application key con permisos de lectura de Logs y Security Signals
#        (Organization Settings > Application Keys). Distinta de la API key.
DATADOG_APP_KEY=
# [PROD] Sitio/región de tu cuenta. DEBE coincidir con el dominio donde inicias
#        sesión en Datadog, o las llamadas fallarán con 403.
#   US1      -> datadoghq.com        (por defecto)
#   US3      -> us3.datadoghq.com
#   US5      -> us5.datadoghq.com
#   EU1      -> datadoghq.eu
#   AP1      -> ap1.datadoghq.com
#   AP2      -> ap2.datadoghq.com
#   US1-FED  -> ddog-gov.com
#   US2-FED  -> us2.ddog-gov.com
DATADOG_SITE=datadoghq.com

# ====== Integración Email (Microsoft Graph / Azure) ======
# mock = no envía, sólo simula | real = envía vía Microsoft Graph
# [PROD] Cambiar a "real".
EMAIL_MODE=mock
# [PROD] Datos de la App Registration en Entra ID (Azure AD).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# [PROD] Secreto de cliente. Requiere permiso de aplicación Mail.Send (con consentimiento de admin).
AZURE_CLIENT_SECRET=
# [PROD] Buzón remitente (UPN o correo) desde el que se envían los reportes.
MAIL_SENDER=
